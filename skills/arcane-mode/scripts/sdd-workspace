#!/usr/bin/env bash
# Resolve and ensure the working-tree directory the pipeline uses for its
# short-lived artifacts: task briefs, implementer reports, review packages,
# and the progress ledger. Prints the directory's absolute path.
#
# Lives in the working tree (not under .git/) because agent writes into
# .git/ are typically denied. A self-ignoring .gitignore keeps the workspace
# out of `git status` without modifying any tracked file.
#
# Single source of truth for the workspace location, so task-brief and
# review-package cannot drift to different directories.
#
# Adapted from superpowers (MIT, Jesse Vincent).
# Usage: sdd-workspace
set -euo pipefail

root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
dir="$root/.catalyst/sdd"
# The contract says the workspace LIVES IN THE WORKING TREE. A symlinked
# component (`.catalyst` or `.catalyst/sdd` pointing outside the repo) would
# silently route every brief/report/package/ledger write out of the tree —
# different per machine, absent on the next one. Refuse symlinks instead of
# following them.
if [ -L "$root/.catalyst" ] || [ -L "$dir" ]; then
  echo "sdd-workspace: $root/.catalyst (or /sdd) is a symlink — the workspace must be a real directory inside the working tree; remove the link" >&2
  exit 2
fi
mkdir -p "$dir"
# Self-heal must guarantee an EFFECTIVE ignore, not just a file: an existing
# empty .gitignore (or one holding only negations) would leak briefs/ledger
# into git status. Preserve user lines (e.g. `!progress.md`); ensure `*`.
if [ ! -f "$dir/.gitignore" ]; then
  printf '*\n' > "$dir/.gitignore"
elif ! grep -qx '\*' "$dir/.gitignore"; then
  { printf '*\n'; cat "$dir/.gitignore"; } > "$dir/.gitignore.tmp" && mv "$dir/.gitignore.tmp" "$dir/.gitignore"
fi
cd "$dir" && pwd
