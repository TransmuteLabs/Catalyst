#!/usr/bin/env bash
# Extract one task's full text from an implementation plan into a file the
# implementer reads in one call, so the task text never has to be pasted
# through the controller's context.
#
# Adapted from superpowers (MIT, Jesse Vincent).
# Usage: task-brief PLAN_FILE TASK_NUMBER [OUTFILE]
# Default OUTFILE: <workspace>/task-<N>-brief.md
# Exit codes: 0 ok; 2 usage / missing plan file / non-numeric task id;
# 3 task not found; 4 duplicate task ids; 5 no paths derivable, an unquoted
# path contains whitespace, a path is UNENCODABLE in the backtick header
# (embedded/unterminated backtick, text outside a closed span), or a path is
# a CASE ALIAS of a tracked file (paths bind by exact git-tree spelling) —
# plan defect, fix the Files block; 6 structural Files conflict: multiple
# **Files:** fields, the inline form mixed with bullet lines, a **Files:**
# line after the task's checklist steps began (step content, never scope),
# or a Files block on an approval task. CRLF plans are normalized (trailing
# CR is line-ending encoding, not content).
set -euo pipefail

if [ $# -lt 2 ] || [ $# -gt 3 ]; then
  echo "usage: task-brief PLAN_FILE TASK_NUMBER [OUTFILE]" >&2
  exit 2
fi

plan=$1
n=$2
# The task id is interpolated into awk REGEXES below — a non-numeric value
# ("3." matches Task 30, "[0-9]+" matches everything) silently extracts a
# DIFFERENT task than the ledger identity records. Digits only.
case "$n" in
  ''|*[!0-9]*) echo "task id must be numeric, got: '$n'" >&2; exit 2 ;;
esac
[ -f "$plan" ] || { echo "no such plan file: $plan" >&2; exit 2; }

if [ $# -eq 3 ]; then
  out=$3
else
  dir=$("$(cd "$(dirname "$0")" && pwd)/sdd-workspace")
  out="$dir/task-${n}-brief.md"
fi

# Duplicate task ids are a silent-loss hazard: two `Task N` headings would
# concatenate into one brief while the ledger holds one identity — one of the
# logical tasks gets skipped or falsely closed. Refuse instead.
# Fence tracking is CommonMark-shaped in every block below: remember the
# opener's character (backtick/tilde) and run length; only a run of the SAME
# character AT LEAST as long closes it — a naive toggle lets an inner ```
# inside a ```` fence "close" it, and a literal task heading in a fixture
# then truncates the real task.
dupes=$(awk -v n="$n" '
  { sub(/\r$/, "") }  # CRLF normalization — same rule as every other pass
  /^(```|~~~)/ {
    match($0, /^(`+|~+)/); ch = substr($0,1,1); len = RLENGTH
    if (!infence) { infence = 1; fch = ch; flen = len }
    else if (ch == fch && len >= flen) infence = 0
  }
  !infence && $0 ~ ("^#+[ \t]+Task[ \t]+" n "([^0-9]|$)") { c++ }
  END { print c+0 }
' "$plan")
if [ "$dupes" -gt 1 ]; then
  echo "plan has ${dupes} headings matching 'Task ${n}' — task ids must be unique; fix the plan first" >&2
  exit 4
fi

extract_task() {
  awk -v n="$n" '
    { sub(/\r$/, "") }  # CRLF plans: the trailing CR is line-ending encoding, not content — normalized ONCE here in every pass (an unstripped CR rode into backtick spans as a path byte and flipped the canonical bulleted form into a false "mixed" refusal)
    /^(```|~~~)/ {
      match($0, /^(`+|~+)/); ch = substr($0,1,1); len = RLENGTH
      if (!infence) { infence = 1; fch = ch; flen = len }
      else if (ch == fch && len >= flen) infence = 0
    }
    !infence && /^#+[ \t]/ {
      match($0, /^#+/); lvl = RLENGTH
      if ($0 ~ /^#+[ \t]+Task[ \t]+[0-9]+/) {
        if ($0 ~ ("^#+[ \t]+Task[ \t]+" n "([^0-9]|$)")) { intask = 1; tlvl = lvl }
        else intask = 0
      } else if (intask && lvl <= tlvl) {
        # a non-task section at the task heading level or higher ends the task:
        # trailing plan prose (rollout notes, open questions) must not leak into
        # the last task brief as if it were requirements
        intask = 0
      }
    }
    intask { print }
  ' "$plan"
}

# Plan-wide Global Constraints implicitly bind every task (plan-standard) —
# a brief that drops them hands the implementer requirements with a hole.
extract_constraints() {
  awk '
    { sub(/\r$/, "") }  # CRLF plans: the trailing CR is line-ending encoding, not content — normalized ONCE here in every pass (an unstripped CR rode into backtick spans as a path byte and flipped the canonical bulleted form into a false "mixed" refusal)
    /^(```|~~~)/ {
      match($0, /^(`+|~+)/); ch = substr($0,1,1); len = RLENGTH
      if (!infence) { infence = 1; fch = ch; flen = len }
      else if (ch == fch && len >= flen) infence = 0
    }
    !infence && /^#+[ \t]/ {
      match($0, /^#+/); lvl = RLENGTH
      if ($0 ~ /^#+[ \t]+Global Constraints/) { insec = 1; slvl = lvl; print; next }
      # A Task heading ends the section regardless of depth: an incomplete
      # plan that omits the peer section between constraints and tasks must
      # not leak every task body into every brief as "constraints".
      else if (insec && (lvl <= slvl || $0 ~ /^#+[ \t]+Task[ \t]+[0-9]+/)) insec = 0
    }
    insec { print }
  ' "$plan"
}

task_text=$(extract_task)
if [ -z "$task_text" ]; then
  echo "task ${n} not found in ${plan} (no heading matching 'Task ${n}')" >&2
  exit 3
fi

# The implementer contract scopes writes by the brief. Surface the task's
# **Files:** list as a canonical `paths:` header line the agent can bind to.
# Both sanctioned plan shapes are parsed: the canonical bulleted block
# (`**Files:**` followed by `- Create:/- Modify:/- Test:` bullets, per
# plan-standard) and the inline `**Files:** a.py, b.py` form. Bullet
# prefixes and `:N-M` line-range suffixes are normalized away.
# ENCODING CONTRACT (the header the implementer parses): every path is
# emitted BACKTICK-QUOTED, separated by `, ` — consumers read the backtick
# spans, never split raw text on commas/whitespace. A plan path containing
# whitespace or commas must be backtick-quoted in the plan (an unquoted
# whitespace path is refused, never silently truncated; the inline split is
# span-aware, so a quoted comma path survives); a path that cannot be
# encoded in backtick spans at all (it contains a literal backtick) is
# refused, never repaired.
# APPROVAL tasks (plan-standard `**Type:** approval`) have no Files block by
# design — orchestrator-owned, never an implementer dispatch. The detection
# is FENCE-AWARE like every other pass (a fenced fixture containing a
# literal `**Type:** approval` line must not reclassify a normal task and
# throw away its real Files scope), and an approval task that DOES carry a
# Files block is a contradictory plan shape — refused, never normalized.
fence_grep() {
  # $1 = anchored regex; prints 1 if a line matches OUTSIDE fences.
  # NB: awk -v PROCESSES backslash escapes in the value — call sites must
  # DOUBLE every backslash or the regex arrives mangled (\* becomes *).
  printf '%s\n' "$task_text" | awk -v pat="$1" '
    { sub(/\r$/, "") }  # CRLF plans: the trailing CR is line-ending encoding, not content — normalized ONCE here in every pass (an unstripped CR rode into backtick spans as a path byte and flipped the canonical bulleted form into a false "mixed" refusal)
    /^(```|~~~)/ {
      match($0, /^(`+|~+)/); ch = substr($0,1,1); len = RLENGTH
      if (!infence) { infence = 1; fch = ch; flen = len }
      else if (ch == fch && len >= flen) infence = 0
      next
    }
    !infence && $0 ~ pat { found = 1 }
    END { print found + 0 }
  '
}
is_approval=$(fence_grep '^\\*\\*Type:\\*\\*[ \t]*approval')
has_files=$(fence_grep '^\\*\\*Files:\\*\\*')
if [ "$is_approval" = 1 ] && [ "$has_files" = 1 ]; then
  echo "task ${n}: **Type:** approval WITH a **Files:** block — approval tasks are orchestrator-owned and have no Files by design; a Files block here is a contradictory plan shape (fix the plan: drop the block or fix the type)" >&2
  exit 6
fi
if [ "$is_approval" = 1 ]; then
  paths_line='(none — approval task, orchestrator-owned; not an implementer dispatch)'
else
  paths_raw=$(printf '%s\n' "$task_text" | awk '
    { sub(/\r$/, "") }  # CRLF plans: the trailing CR is line-ending encoding, not content — normalized ONCE here in every pass (an unstripped CR rode into backtick spans as a path byte and flipped the canonical bulleted form into a false "mixed" refusal)
    /^(```|~~~)/ {
      match($0, /^(`+|~+)/); ch = substr($0,1,1); len = RLENGTH
      if (!infence) { infence = 1; fch = ch; flen = len }
      else if (ch == fch && len >= flen) infence = 0
      next
    }
    infence { next }
    # norm(): backtick discipline is REFUSE-ON-DOUBT, never repair — the
    # header binds the implementer write scope, and a silently mangled path
    # (stripped tick, truncated span) binds it to a file the plan never
    # named. Unencodable shapes: an unquoted path containing a backtick, an
    # opening backtick with no closing one, and trailing text after a
    # closed span (other than a :N-M range).
    function norm(p,   tail, inner) {
      sub(/^(Create|Modify|Test|Delete):[ \t]*/, "", p)
      gsub(/^[ \t]+/, "", p); gsub(/[ \t]+$/, "", p)
      quoted = 0
      if (p == "") return ""
      if (p ~ /^`/) {
        if (!match(p, /^`[^`]+`/)) { printf "ERR:tick:%s\n", p; err = 1; exit 1 }
        inner = substr(p, 2, RLENGTH - 2)
        tail = substr(p, RLENGTH + 1)
        if (tail !~ /^[ \t]*$/ && tail !~ /^:[0-9]+(-[0-9]+)?[ \t]*$/) { printf "ERR:tick:%s\n", p; err = 1; exit 1 }
        p = inner; quoted = 1
      } else if (p ~ /`/) {
        printf "ERR:tick:%s\n", p; err = 1; exit 1
      }
      sub(/:[0-9]+(-[0-9]+)?$/, "", p)
      return p
    }
    function add(p) {
      if (p == "") return
      if (!quoted && p ~ /[ \t\r]/) { printf "ERR:ws:%s\n", p; err = 1; exit 1 }
      out = out (out == "" ? "" : ", ") "`" p "`"
    }
    # After an INLINE Files field, bullet lines are the MIXED form — refused:
    # silently dropping them ships a partial write scope under a valid-looking
    # header (blank lines between the field and the bullets do not clear the
    # watch). The watch does NOT die at the first prose line: it degrades to
    # op-bullet watching for the REST of the task — a `- Create:/Modify:/
    # Test:/Delete:` bullet anywhere after an inline field is Files intent
    # that would silently miss the write scope (one intervening prose line
    # previously defeated the whole guard).
    # A checklist step (`- [ ]`) is unambiguously a STEP, never a Files
    # bullet: it ends the bulleted Files block (canonical plans without a
    # blank line between the block and the steps previously fed "[ ] step"
    # into the path normalizer), clears the strict inline watch (a step
    # right after an inline field is the canonical anatomy, not the mixed
    # form), and marks the steps as begun for the positional gate below.
    /^-[ \t]+\[[ xX]?\]/ { steps = 1; if (mixwatch == 1) mixwatch = 2; inblock = 0 }
    # A `Steps:` header or numbered steps (1. / 1)) mark the steps as begun
    # too — a plan violating the checkbox norm previously got ZERO positional
    # protection, and the unfenced-illustration harvest returned whole.
    /^Steps:[ \t]*$/ { steps = 1 }
    /^[0-9]+[.)][ \t]/ { steps = 1 }
    mixwatch == 1 {
      if ($0 ~ /^-[ \t]+/) { printf "ERR:mixed:\n"; err = 1; exit 1 }
      if ($0 !~ /^[ \t]*$/) mixwatch = 2
    }
    mixwatch == 2 && /^-[ \t]+(Create|Modify|Test|Delete):/ {
      printf "ERR:mixed:\n"; err = 1; exit 1
    }
    inblock {
      if ($0 ~ /^-[ \t]+/) { p = $0; sub(/^-[ \t]+/, "", p); add(norm(p)); next }
      inblock = 0
    }
    # Positional grammar: the Files field belongs to the task HEADER (after
    # Type, before the steps — plan-standard anatomy). Once a checklist step
    # has appeared, a **Files:** line is CONTENT (an unfenced illustration in
    # a step body) or a misplaced field — refused, never harvested: a
    # tutorial example was previously minted into the write scope, binding
    # the implementer to files the plan never authorized. (Residual: an
    # unfenced example BEFORE any checklist line still parses as grammar —
    # fence illustrations, per plan-standard.)
    /^\*\*Files:\*\*/ {
      if (steps) { printf "ERR:late:\n"; err = 1; exit 1 }
      if (seen) { printf "ERR:dupfiles:\n"; err = 1; exit 1 }
      seen = 1
      rest = $0
      sub(/^\*\*Files:\*\*[ \t]*/, "", rest)
      if (rest != "") {
        # Span-aware inline split: commas INSIDE a backtick span are part of
        # the path (a naive split halved the span into two nonexistent
        # paths); an unterminated span is unencodable.
        cnt = 0; cur = ""; ins = 0
        for (i = 1; i <= length(rest); i++) {
          c = substr(rest, i, 1)
          if (c == "`") { ins = !ins; cur = cur c }
          else if (c == "," && !ins) { arr[++cnt] = cur; cur = "" }
          else cur = cur c
        }
        if (ins) { printf "ERR:tick:%s\n", rest; err = 1; exit 1 }
        arr[++cnt] = cur
        for (i = 1; i <= cnt; i++) add(norm(arr[i]))
        mixwatch = 1
      } else inblock = 1
    }
    END { if (!err) print out }
  ' || true)
  case "$paths_raw" in
    ERR:dupfiles:*)
      echo "task ${n}: multiple **Files:** fields in one task — a later inline field would shadow the canonical block; keep exactly one Files field per task" >&2
      exit 6 ;;
    ERR:mixed:*)
      echo "task ${n}: inline **Files:** field followed by bullet lines — the mixed form silently drops the bullets from the write scope; use ONE form (the canonical bulleted block, or a purely inline list)" >&2
      exit 6 ;;
    ERR:late:*)
      echo "task ${n}: a **Files:** line after the task's checklist steps began — that is step CONTENT (an unfenced illustration) or a misplaced field, never the write scope; move the Files field into the task header, or fence the illustration" >&2
      exit 6 ;;
    ERR:ws:*)
      echo "task ${n}: unquoted path contains whitespace: '${paths_raw#ERR:ws:}' — backtick-quote the path in the plan's Files block (silent truncation would bind the write scope to a wrong path)" >&2
      exit 5 ;;
    ERR:tick:*)
      echo "task ${n}: path not encodable in the backtick header: '${paths_raw#ERR:tick:}' — embedded/unterminated backtick or text outside a closed span; fix the plan's Files entry (a repaired path would bind the write scope to a file the plan never named)" >&2
      exit 5 ;;
  esac
  paths_line=$paths_raw
  # ALIAS GATE: repository paths bind by their exact git-tree BYTE spelling —
  # a case-insensitive filesystem (macOS APFS) resolves `SRC/App.py` to a
  # tracked `src/app.py`, so the implementer "successfully" edits a file the
  # scope never named while `git rev-parse HEAD:<path>` calls it absent. A
  # derived path that is NOT byte-exact tracked but casefold-equal to a
  # tracked path is refused. (Unicode-normalization aliases are covered by
  # the doctrine's tree-spelling rule — not shell-checkable portably; paths
  # that are simply untracked-yet (files a later task creates) pass.)
  # Anchored to the PLAN'S repository, never the caller's cwd: `git ls-files`
  # from a subdirectory lists only paths UNDER the cwd (silently disabling
  # the gate) and cwd-relative (falsely refusing `App.py` against a tracked
  # `src/app.py` when run from src/); and a plan passed by absolute path
  # from another repo must be checked against ITS OWN tree.
  plandir=$(cd "$(dirname "$plan")" && pwd)
  if top=$(git -C "$plandir" rev-parse --show-toplevel 2>/dev/null); then
    tracked=$(git -C "$top" ls-files 2>/dev/null || true)
    if [ -n "$tracked" ]; then
      # Casefold the tracked set ONCE (a per-tracked-path subprocess loop
      # measured 650+ s on 300 paths x 5k tracked — two forks per tracked
      # file); C locale pins ASCII folding deterministically.
      pairs=$(printf '%s\n' "$tracked" | LC_ALL=C awk '{ print tolower($0) "\t" $0 }')
      while IFS= read -r p; do
        [ -n "$p" ] || continue
        if printf '%s\n' "$tracked" | grep -qxF -- "$p"; then continue; fi
        lc=$(printf '%s' "$p" | LC_ALL=C tr '[:upper:]' '[:lower:]')
        # ENVIRON, not -v: awk -v processes backslash escapes (the fence_grep NB)
        hit=$(printf '%s\n' "$pairs" | LC_ALL=C K="$lc" awk -F'\t' '$1 == ENVIRON["K"] { print $2; exit }')
        if [ -n "$hit" ]; then
          echo "task ${n}: path '$p' is a case alias of tracked '$hit' — repository paths bind by exact tree spelling (an alias resolves on this filesystem but is a different identity in git and on case-sensitive systems); fix the plan's Files entry" >&2
          exit 5
        fi
      done <<EOF_PATHS
$(printf '%s\n' "$paths_line" | awk -F'`' '{ for (i = 2; i <= NF; i += 2) print $i }')
EOF_PATHS
    fi
  fi
fi

# Fail closed: a brief without `paths:` leaves the implementer write-scope
# contract undefined (dispatch-templates makes the header mandatory). An
# empty extraction means the plan's Files field is missing or malformed —
# that is a plan defect to fix, not a header to silently omit.
if [ -z "$paths_line" ]; then
  echo "task ${n}: no paths extracted from a **Files:** field — the implementer write scope binds to the brief's paths: header; fix the plan's Files block (canonical bulleted form or inline **Files:** a.py, b.py)" >&2
  exit 5
fi

# Temp-then-atomic-rename with a TERMINAL MARKER (the review-package shield):
# a direct `> $out` first TRUNCATES a prior complete brief, and a kill/ENOSPC
# mid-write leaves a valid-looking header + a silent prefix of the task —
# the implementer's only structural check is the paths: header, so thousands
# of dropped requirements would pass unnoticed. The reader requires the
# marker (implementer contract).
tmp="$out.tmp.$$"
{
  printf 'paths: %s\n\n' "$paths_line"
  constraints=$(extract_constraints)
  if [ -n "$constraints" ]; then
    printf '%s\n\n' "$constraints"
  fi
  printf '%s\n' "$task_text"
  printf '\n<!-- BRIEF COMPLETE -->\n'
} > "$tmp" && mv "$tmp" "$out"

echo "wrote ${out}: $(wc -l < "$out" | tr -d ' ') lines"
