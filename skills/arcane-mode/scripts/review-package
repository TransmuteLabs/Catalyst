#!/usr/bin/env bash
# Generate a review package: commit list, stat summary, and the net
# diff with extended context, written to a file the reviewer reads in one
# call. Using the recorded per-task BASE (not HEAD~1) keeps multi-commit
# tasks intact.
#
# Adapted from superpowers (MIT, Jesse Vincent).
# Usage: review-package BASE HEAD [OUTFILE]
# Default OUTFILE: <workspace>/review-<base7>..<head7>.diff
# (named per range, so a re-review after fixes gets a distinct fresh file).
set -euo pipefail

if [ $# -lt 2 ] || [ $# -gt 3 ]; then
  echo "usage: review-package BASE HEAD [OUTFILE]" >&2
  exit 2
fi

base=$1
head=$2

git rev-parse --verify --quiet "$base" >/dev/null || { echo "bad BASE: $base" >&2; exit 2; }
git rev-parse --verify --quiet "$head" >/dev/null || { echo "bad HEAD: $head" >&2; exit 2; }

if [ $# -eq 3 ]; then
  out=$3
else
  dir=$("$(cd "$(dirname "$0")" && pwd)/sdd-workspace")
  out="$dir/review-$(git rev-parse --short "$base")..$(git rev-parse --short "$head").diff"
fi

# Full OIDs in the package metadata: short prefixes are unique only against
# the object database at write time — a later fetch can make a stored prefix
# ambiguous. Short forms stay display-only (the filename).
base_full=$(git rev-parse "${base}^{commit}")
head_full=$(git rev-parse "${head}^{commit}")

# Write to a temp file and rename atomically: a direct redirect creates the
# final path first, so a kill/ENOSPC mid-write leaves a plausible truncated
# package (and regenerating destroys the previous complete one first). The
# terminal marker lets any reader verify completeness.
tmp=$(mktemp "${out}.XXXXXX")
trap 'rm -f "$tmp"' EXIT
{
  echo "# Review package: ${base_full}..${head_full}"
  echo
  echo "## Commits"
  git log --oneline "${base_full}..${head_full}"
  echo
  echo "## Files changed"
  git diff --stat "${base_full}..${head_full}"
  echo
  echo "## Diff"
  git diff -U10 "${base_full}..${head_full}"
  echo
  echo "## End of package (complete)"
} > "$tmp"
mv "$tmp" "$out"
trap - EXIT

commits=$(git rev-list --count "${base_full}..${head_full}")
echo "wrote ${out}: ${commits} commit(s), $(wc -c < "$out" | tr -d ' ') bytes"
