{
  "name": "catalyst-envoy",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "Envoy companion runtime for the Catalyst family - drive external harnesses (codex today; grok/kimi next) from Claude Code.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "bump-version": "node scripts/bump-version.mjs",
    "check-version": "node scripts/bump-version.mjs --check",
    "prebuild": "mkdir -p .generated/app-server-types && codex app-server generate-ts --out .generated/app-server-types",
    "build": "tsc -p tsconfig.app-server.json",
    "test": "node --test tests/*.test.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
